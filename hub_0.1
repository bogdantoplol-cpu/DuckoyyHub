--------------------------------------------------
-- EXECUTE HUB
--------------------------------------------------

local function ExecuteHub()

    -- GUI fade out
    task.spawn(function()
        for i = 1,10 do
            frame.BackgroundTransparency = i/10
            task.wait(0.03)
        end
        frame.Visible = false
    end)

    -- blur remove
    task.spawn(function()
        for i = 20,0,-1 do
            blur.Size = i
            task.wait(0.02)
        end
        blur:Destroy()
    end)

    -- particles remove
    task.spawn(function()
        for _,v in pairs(particleFrame:GetChildren()) do
            v:Destroy()
        end
        particleFrame:Destroy()
    end)

    local scriptUrl = Scripts[game.PlaceId]

    if scriptUrl then
        task.wait(0.4)
        pcall(function()
            loadstring(game:HttpGet(scriptUrl))()
        end)
    else
        player:Kick("Hub not supported")
    end
end

